# ============================================================
#  Fortunas AI — .env PRODUCTION (VPS). Copy jadi .env di server.
#  JANGAN commit file .env asli. Permission ketat: chmod 600 .env
# ============================================================

# ── LLM (Gemini) ─────────────────────────────────────────
LLM_PROVIDER=gemini
GEMINI_API_KEY=ISI_KEY_GEMINI_KAMU
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Auth (WAJIB ganti di production!) ────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=GANTI_DENGAN_HASIL_openssl_rand_hex_32
JWT_EXPIRE_DAYS=7

# ── BigQuery ─────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/opt/fortunas-ai/credentials/fortunas-service-account.json
BIGQUERY_PROJECT_ID=fortunasai
BIGQUERY_DATASET=fortunas_ai
# Tabel default (dipakai backward-compat saja; tenant pakai {prefix}_transactions)
BIGQUERY_TABLE=online_retail

# ── Metadata DB (SQLite untuk tenants/users) ─────────────
FORTUNAS_DB_PATH=/opt/fortunas-ai/app/data/fortunas.db

# ── CORS (mobile native tidak butuh; web/* boleh) ───────
CORS_ORIGINS=*

# ── Multi-tenant: voice tulis beneran ke BigQuery ────────
VOICE_DRY_RUN=false

# ── Scheduler dimatikan (briefing per-tenant on-demand) ──
BRIEFING_SCHEDULER_ENABLED=false
WA_RETRY_ENABLED=false

# ── RAG (opsional) ───────────────────────────────────────
CHROMA_DB_PATH=/opt/fortunas-ai/chroma_db
RAG_COLLECTION_NAME=umkm_knowledge
RAG_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
