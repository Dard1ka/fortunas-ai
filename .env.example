# ================================================================
#  Fortunas AI — .env template (multi-tenant). Copy: cp .env.example .env
#  NEVER commit your real .env or credentials/ JSON.
#  Production template: deploy/.env.production.example
# ================================================================

# ── LLM provider ──────────────────────────────────────────────
# gemini (default) | openai | ollama (local Qwen, zero-cost)
LLM_PROVIDER=gemini

# Gemini (Google AI) — key via ?key= (native API)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI (optional, if LLM_PROVIDER=openai)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Ollama (optional, if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# ── Auth ──────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32
JWT_EXPIRE_DAYS=7
# SQLite store for accounts/tenants
FORTUNAS_DB_PATH=./app/data/fortunas.db

# ── BigQuery ──────────────────────────────────────────────────
# Service account needs BigQuery Data Editor + Job User
GOOGLE_APPLICATION_CREDENTIALS=./credentials/fortunas-service-account.json
BIGQUERY_PROJECT_ID=fortunasai
BIGQUERY_DATASET=fortunas_ai
# Default table (backward-compat only; tenants use {prefix}_transactions)
BIGQUERY_TABLE=online_retail

# ── RAG (ChromaDB + sentence-transformers) ───────────────────
CHROMA_DB_PATH=./chroma_db
RAG_COLLECTION_NAME=umkm_knowledge
RAG_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_DEFAULT_N_RESULTS=4

# ── Voice / behavior ──────────────────────────────────────────
# true = /voice/transaction validates only, no BigQuery write (UI testing)
VOICE_DRY_RUN=false

# ── Scheduler (off for multi-tenant; briefing is on-demand per tenant) ──
BRIEFING_SCHEDULER_ENABLED=false
WA_RETRY_ENABLED=false

# ── CORS (mobile native doesn't need it; web/* ok) ───────────
# Production: CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:3000

# ── Report storage (per-tenant files derived from this base) ──
DAILY_REPORT_PATH=./app/data/daily_reports.json
DAILY_REPORT_HISTORY_DAYS=7
KNOWLEDGE_DOCS_DIR=./app/knowledge/umkm_docs
