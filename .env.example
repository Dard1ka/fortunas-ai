# ================================================================
#  Fortunas AI — Environment Configuration Template
#  1. Copy: cp .env.example .env
#  2. Fill in your values below
#  NEVER commit .env or your service-account.json to git!
# ================================================================

# ── Google BigQuery ──────────────────────────────────────────────
# Absolute path to your GCP service account JSON.
# Required roles: BigQuery Data Editor + BigQuery Job User
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=fortunas_ai
BIGQUERY_TABLE=online_retail

# ── Google Sheets (staging / audit trail) ───────────────────────
# Get Sheet ID from URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
# Share the sheet with your service account email as Editor.
GOOGLE_SHEETS_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_TAB=wa_transactions

# ── Ollama (Local LLM) ───────────────────────────────────────────
# Run: ollama serve  (keep running in separate terminal)
# Pull: ollama pull qwen3:8b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

# ── RAG — ChromaDB + Sentence Transformers ───────────────────────
CHROMA_DB_PATH=./chroma_db
RAG_COLLECTION_NAME=umkm_knowledge
RAG_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RAG_DEFAULT_N_RESULTS=4

# ── WA Simulator (Frontend Chat) ─────────────────────────────────
# MVP uses frontend WhatsApp-style chat simulator.
# Set META_SEND_REPLY=false to disable actual outbound WA messages.
# For future real WA integration, fill in the Meta credentials below.
META_SEND_REPLY=false
META_VERIFY_TOKEN=your-custom-verify-token
META_ACCESS_TOKEN=your-meta-access-token
META_PHONE_NUMBER_ID=your-phone-number-id
META_API_VERSION=v21.0
WA_ALLOWED_SENDERS=

# Auto-retry failed/pending rows → BigQuery
WA_RETRY_ENABLED=true
WA_RETRY_INTERVAL_MINUTES=15

# ── Daily Briefing Scheduler ─────────────────────────────────────
BRIEFING_CRON_HOUR=6
BRIEFING_CRON_MINUTE=0
BRIEFING_TIMEZONE=Asia/Jakarta
BRIEFING_SCHEDULER_ENABLED=true

# ── Report Storage ───────────────────────────────────────────────
DAILY_REPORT_PATH=./app/data/daily_reports.json
DAILY_REPORT_HISTORY_DAYS=7

# ── Knowledge Base ───────────────────────────────────────────────
KNOWLEDGE_DOCS_DIR=./app/knowledge/umkm_docs
